# Database
DATABASE_URL=postgresql://username:password@localhost:5432/article_bot

# Telegram Bot
ARTICLE_BOT_TOKEN=your_telegram_bot_token_here

# AI Services (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Embeddings
EMBEDDING_PROVIDER=fake
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536
# FAKE_EMBEDDING_DIMENSIONS=32

# Critical review generation
REVIEW_GENERATOR_PROVIDER=fake
# REVIEW_GENERATOR_PROVIDER=openai
# OPENAI_REVIEW_MODEL=gpt-5.5-mini
# OPENAI_REVIEW_TEMPERATURE=0.3
# OPENAI_BASE_URL=

# Daily editorial digest job
DAILY_DIGEST_ENABLED=false
DAILY_DIGEST_RUN_AT=09:00
DAILY_DIGEST_PERIOD_DAYS=3
DAILY_DIGEST_MAX_ARTICLES=5
DAILY_DIGEST_TOPIC=AI agents, knowledge bases, requirements, product and engineering practice
DAILY_DIGEST_PUBLISH_ENABLED=false

# Telegram channel publishing for digest/reviews
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_channel_or_chat_id_here

# Authentication and Security
JWT_SECRET_KEY=<generate-a-long-random-jwt-secret>
API_KEY=<generate-a-long-random-api-key>

# Web Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
# Optional regular web user
# WEB_USER_USERNAME=user
# WEB_USER_PASSWORD=change-this-password-too

# Rate Limiting (optional)
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100

# Gmail Ingestion (Phase 7)
GMAIL_ENABLED=false
GMAIL_EMAIL=your_gmail_email_here@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
GMAIL_FOLDER=INBOX
GMAIL_POLL_SECONDS=300

# TranscribeIt Integration (Phase 8)
TRANSCRIBEIT_API_KEY=your_transcribeit_api_key_here
TRANSCRIBEIT_API_URL=https://www.transcribeit.ru
